<style>
.contact-grid{display:grid;grid-template-columns:1fr 1.6fr;gap:64px;align-items:start}
.contact-info{display:flex;flex-direction:column;gap:24px}
.info-block{display:flex;gap:18px;align-items:flex-start;padding:24px;background:var(--white);border:1px solid var(--fog);border-radius:var(--radius-md);transition:all var(--tr)}
.info-block:hover{border-color:var(--amber-lt);box-shadow:var(--shadow-sm)}
.info-icon{width:44px;height:44px;border-radius:10px;background:linear-gradient(135deg,rgba(232,144,58,.15),rgba(232,144,58,.05));border:1px solid rgba(232,144,58,.2);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.info-icon svg{width:20px;height:20px;fill:none;stroke:var(--amber);stroke-width:1.8}
.info-block h4{font-size:.88rem;margin-bottom:4px}
.info-block p,.info-block a{font-size:.88rem;color:var(--steel-2);max-width:none}
.info-block a{color:var(--amber);transition:opacity var(--tr)}
.info-block a:hover{opacity:.8}
.form-card{background:var(--white);border:1px solid var(--fog);border-radius:var(--radius-lg);padding:48px;box-shadow:var(--shadow-md)}
.form-card h2{margin-bottom:8px}
.form-card>p{margin-bottom:32px;font-size:.92rem}
.office-cards{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:24px}
.office-card{background:var(--ink-2);border:1px solid rgba(255,255,255,.08);border-radius:var(--radius-md);padding:24px}
.office-card h4{color:white;font-size:.9rem;margin-bottom:4px;display:flex;align-items:center;gap:8px}
.office-card p{color:var(--mist);font-size:.82rem;max-width:none;line-height:1.6}
@media(max-width:1024px){.contact-grid{grid-template-columns:1fr}}
@media(max-width:600px){.form-card{padding:28px}.office-cards{grid-template-columns:1fr}}
</style>
</head>
