<section class="section">
  <div class="container">
    <div class="contact-grid">

      <!-- LEFT: Info blocks -->
      <div class="contact-info reveal">
        <div class="info-block">
          <div class="info-icon"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg></div>
          <div>
            <h4>Phone</h4>
            <a href="tel:+14165550123">+1 (416) 555-0123</a>
            <p style="margin-top:2px">Mon–Fri, 8am–6pm EST</p>
          </div>
        </div>
        <div class="info-block">
          <div class="info-icon"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
          <div>
            <h4>Email</h4>
            <a href="mailto:hello@settlinks.com">hello@settlinks.com</a>
            <p style="margin-top:2px">We reply within 1 business day</p>
          </div>
        </div>
        <div class="info-block">
          <div class="info-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg></div>
          <div>
            <h4>Response Time</h4>
            <p>All inquiries receive a response within <strong>1 business day</strong>. Discovery calls are typically scheduled within 2–3 business days of initial contact.</p>
          </div>
        </div>
        <div class="info-block">
          <div class="info-icon"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <div>
            <h4>Confidentiality</h4>
            <p>All information shared with Settlinks is treated as strictly confidential. NDAs are available upon request before any detailed discussions.</p>
          </div>
        </div>
        <div class="info-block">
          <div class="info-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 10-16 0c0 3 2.7 6.9 8 11.7z"/></svg></div>
          <div>
            <h4>Our Offices</h4>
            <div class="office-cards" style="margin-top:10px">
              <div class="office-card">
                <h4>🇨🇦 Toronto HQ</h4>
                <p>123 Bay Street, Suite 400<br>Toronto, ON, M5H 2R3<br>Canada</p>
              </div>
              <div class="office-card">
                <h4>🇲🇽 Monterrey</h4>
                <p>Av. Insurgentes 450, Piso 8<br>Monterrey, N.L. 64000<br>Mexico</p>
              </div>
            </div>
          </div>
        </div>
